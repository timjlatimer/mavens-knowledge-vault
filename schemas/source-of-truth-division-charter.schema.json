{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/timjlatimer/mavens-knowledge-vault/schemas/source-of-truth-division-charter.schema.json",
  "title": "Source of Truth Division Charter v1.1 Enforcement Schema",
  "description": "Machine-enforceable companion schema for the Source of Truth Division Charter v1.1. All division governance outputs must validate against this schema. Failure to validate = REJECTED.",
  "type": "object",
  "required": [
    "schema_version",
    "skill_reference",
    "division_structure",
    "three_lines_model",
    "governance_principles",
    "charter_approval"
  ],
  "properties": {
    "schema_version": {
      "const": "1.1",
      "description": "Must match the current Charter version."
    },
    "skill_reference": {
      "type": "object",
      "required": ["skill_name", "version", "vault_path", "schema_path"],
      "properties": {
        "skill_name": { "const": "source_of_truth_division_charter" },
        "version": { "const": "1.1" },
        "vault_path": { "const": "/skills/source-of-truth-division-charter.md" },
        "schema_path": { "const": "/schemas/source-of-truth-division-charter.schema.json" }
      }
    },
    "division_structure": {
      "type": "object",
      "description": "The organizational structure of the Source of Truth Division.",
      "required": ["division_name", "reports_to", "citation_officer", "watchman"],
      "properties": {
        "division_name": { "const": "Source of Truth Division" },
        "reports_to": {
          "const": "TIM_HB1000",
          "description": "Both agents report directly to Tim HB1000 (board-level, not filtered through Master Jeeves)."
        },
        "citation_officer": {
          "type": "object",
          "required": ["role", "version", "line_of_defense", "reports_to", "independence_from_master_jeeves"],
          "properties": {
            "role": { "const": "Second Line — Citation Verification Gate" },
            "version": { "type": "string", "minLength": 1 },
            "line_of_defense": { "const": "second_line" },
            "reports_to": { "const": "TIM_HB1000_DIRECT" },
            "independence_from_master_jeeves": {
              "const": true,
              "description": "Citation Officer operates independently of Master Jeeves."
            }
          }
        },
        "watchman": {
          "type": "object",
          "required": ["role", "version", "line_of_defense", "reports_to", "independence_from_master_jeeves"],
          "properties": {
            "role": { "const": "Third Line — Independent Audit" },
            "version": { "type": "string", "minLength": 1 },
            "line_of_defense": { "const": "third_line" },
            "reports_to": { "const": "TIM_HB1000_DIRECT" },
            "independence_from_master_jeeves": {
              "const": true,
              "description": "The Watchman operates independently of Master Jeeves."
            }
          }
        }
      }
    },
    "three_lines_model": {
      "type": "object",
      "description": "The Three Lines of Defense model adapted from the IIA framework.",
      "required": ["first_line", "second_line", "third_line"],
      "properties": {
        "first_line": {
          "type": "object",
          "required": ["name", "description", "agents"],
          "properties": {
            "name": { "const": "Agent Self-Enforcement" },
            "description": {
              "type": "string",
              "description": "Every agent is responsible for its own compliance via Iron Brief self-enforcement protocol."
            },
            "agents": {
              "type": "array",
              "description": "All agents in the ecosystem. First line applies to everyone.",
              "items": { "type": "string" },
              "minItems": 1
            }
          }
        },
        "second_line": {
          "type": "object",
          "required": ["name", "description", "agent"],
          "properties": {
            "name": { "const": "Citation Verification Gate" },
            "description": {
              "type": "string",
              "description": "The Citation Officer verifies all definitive claims trace to real sources before distribution."
            },
            "agent": { "const": "citation_officer" }
          }
        },
        "third_line": {
          "type": "object",
          "required": ["name", "description", "agent"],
          "properties": {
            "name": { "const": "Independent Audit" },
            "description": {
              "type": "string",
              "description": "The Watchman conducts independent audits of all agent outputs against all governance standards."
            },
            "agent": { "const": "the_watchman" }
          }
        }
      }
    },
    "governance_principles": {
      "type": "object",
      "description": "Core governance principles that bind the division.",
      "required": [
        "independence",
        "transparency",
        "proportionality",
        "continuous_improvement",
        "board_reporting"
      ],
      "properties": {
        "independence": {
          "type": "object",
          "required": ["statement", "enforced"],
          "properties": {
            "statement": {
              "type": "string",
              "description": "Both agents operate independently of the agents they audit."
            },
            "enforced": { "const": true }
          }
        },
        "transparency": {
          "type": "object",
          "required": ["statement", "enforced"],
          "properties": {
            "statement": {
              "type": "string",
              "description": "All audit findings, citation verdicts, and escalations are logged and accessible."
            },
            "enforced": { "const": true }
          }
        },
        "proportionality": {
          "type": "object",
          "required": ["statement", "enforced"],
          "properties": {
            "statement": {
              "type": "string",
              "description": "Rigor is proportional to materiality tier. Draft brainstorms are not held to the same standard as strategic deliverables."
            },
            "enforced": { "const": true }
          }
        },
        "continuous_improvement": {
          "type": "object",
          "required": ["statement", "enforced"],
          "properties": {
            "statement": {
              "type": "string",
              "description": "Both agents participate in V13.1 Learning Loops and self-improvement cycles."
            },
            "enforced": { "const": true }
          }
        },
        "board_reporting": {
          "type": "object",
          "required": ["statement", "enforced"],
          "properties": {
            "statement": {
              "type": "string",
              "description": "Both agents report directly to Tim HB1000. Reports are unfiltered and unedited."
            },
            "enforced": { "const": true }
          }
        }
      }
    },
    "charter_approval": {
      "type": "object",
      "required": ["approved_by", "approval_date", "charter_version", "status"],
      "properties": {
        "approved_by": { "const": "TIM_HB1000" },
        "approval_date": { "type": "string", "format": "date" },
        "charter_version": { "const": "1.1" },
        "status": {
          "type": "string",
          "enum": ["ACTIVE", "SUPERSEDED", "DRAFT"]
        }
      }
    }
  },
  "additionalProperties": false
}
