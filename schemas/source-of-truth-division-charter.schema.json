{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/timjlatimer/mavens-knowledge-vault/schemas/source-of-truth-division-charter.schema.json",
  "title": "Source of Truth Division Charter v1.3 Enforcement Schema",
  "description": "Machine-enforceable companion schema for the Source of Truth Division Charter v1.3. All division governance outputs must validate against this schema. Failure to validate = REJECTED.",
  "type": "object",
  "required": [
    "schema_version",
    "skill_reference",
    "division_structure",
    "governance_principles",
    "charter_approval"
  ],
  "properties": {
    "schema_version": {
      "const": "1.3",
      "description": "Must match the current Charter version."
    },
    "skill_reference": {
      "type": "object",
      "required": ["skill_name", "version", "vault_path", "schema_path"],
      "properties": {
        "skill_name": { "const": "source_of_truth_division_charter" },
        "version": { "const": "1.3" },
        "vault_path": { "const": "/skills/source-of-truth-division-charter.md" },
        "schema_path": { "const": "/schemas/source-of-truth-division-charter.schema.json" }
      }
    },
    "division_structure": {
      "type": "object",
      "description": "The organizational structure of the Source of Truth Division.",
      "required": ["division_name", "reports_to", "harvester", "archivist", "citation_officer", "watchman"],
      "properties": {
        "division_name": { "const": "Source of Truth Division" },
        "reports_to": {
          "const": "TIM_HB1000",
          "description": "All agents report directly to Tim HB1000 (board-level, not filtered through Master Jeeves)."
        },
        "harvester": {
            "type": "object",
            "required": ["role", "version"],
            "properties": {
                "role": {"const": "First Role — Retrieval"},
                "version": {"type": "string", "minLength": 1}
            }
        },
        "archivist": {
          "type": "object",
          "required": ["role", "version"],
          "properties": {
            "role": { "const": "Second Role — Intake and Library" },
            "version": { "type": "string", "minLength": 1 }
          }
        },
        "citation_officer": {
          "type": "object",
          "required": ["role", "version"],
          "properties": {
            "role": { "const": "Third Role — Citation Verification Gate" },
            "version": { "type": "string", "minLength": 1 }
          }
        },
        "watchman": {
          "type": "object",
          "required": ["role", "version"],
          "properties": {
            "role": { "const": "Fourth Role — Independent Audit" },
            "version": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "governance_principles": {
      "type": "object",
      "required": [
        "independence",
        "transparency",
        "proportionality",
        "continuous_improvement",
        "board_reporting"
      ],
      "properties": {
        "independence": {
          "type": "object",
          "required": ["statement", "enforced"],
          "properties": {
            "statement": { "type": "string" },
            "enforced": { "const": true }
          }
        },
        "transparency": {
          "type": "object",
          "required": ["statement", "enforced"],
          "properties": {
            "statement": { "type": "string" },
            "enforced": { "const": true }
          }
        },
        "proportionality": {
          "type": "object",
          "required": ["statement", "enforced"],
          "properties": {
            "statement": { "type": "string" },
            "enforced": { "const": true }
          }
        },
        "continuous_improvement": {
          "type": "object",
          "required": ["statement", "enforced"],
          "properties": {
            "statement": { "type": "string" },
            "enforced": { "const": true }
          }
        },
        "board_reporting": {
          "type": "object",
          "required": ["statement", "enforced"],
          "properties": {
            "statement": { "type": "string" },
            "enforced": { "const": true }
          }
        }
      }
    },
    "charter_approval": {
      "type": "object",
      "required": ["approved_by", "approval_date", "charter_version", "status"],
      "properties": {
        "approved_by": { "const": "TIM_HB1000" },
        "approval_date": { "type": "string", "format": "date" },
        "charter_version": { "const": "1.3" },
        "status": {
          "type": "string",
          "enum": ["ACTIVE", "SUPERSEDED", "DRAFT"]
        }
      }
    }
  },
  "additionalProperties": false
}
