{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/timjlatimer/mavens-knowledge-vault/schemas/the-archivist.schema.json",
  "title": "The Archivist v1.0 Enforcement Schema",
  "description": "Machine-enforceable companion schema for The Archivist skill. All intake, proactive intelligence, and discard intelligence outputs must validate against this schema. Failure to validate = REJECTED.",
  "type": "object",
  "required": ["operating_mode"],
  "properties": {
    "operating_mode": {
      "type": "string",
      "enum": ["REACTIVE", "PROACTIVE", "BOTH"]
    },
    "intake_item": {
      "$ref": "#/definitions/vault_item"
    },
    "proactive_scan_results": {
      "type": "array",
      "description": "Array of intelligence briefs generated in PROACTIVE mode.",
      "items": {
        "$ref": "#/definitions/intelligence_brief"
      }
    },
    "discard_intelligence_db": {
      "type": "object",
      "required": ["path", "entries"],
      "properties": {
        "path": { "const": "/discard-intelligence/discard-db.json" },
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/discarded_item"
          }
        }
      }
    },
    "swarm_signal": {
      "$ref": "#/definitions/swarm_signal_brief"
    },
    "pattern_analysis_cadence": {
      "const": "RHYTHM",
      "description": "Pattern analysis for swarm signals runs on the monthly Rhythm cycle."
    }
  },
  "definitions": {
    "vault_item": {
      "type": "object",
      "description": "Schema for a single item being processed in REACTIVE intake mode.",
      "required": [
        "project",
        "north_star",
        "document_type",
        "source_type",
        "citation_tier",
        "date_ingested",
        "ingested_by",
        "vault_path",
        "duplicate_check_performed",
        "pii_scan_performed"
      ],
      "properties": {
        "project": { "type": "string", "minLength": 1 },
        "north_star": { "type": "string", "minLength": 1 },
        "document_type": { "type": "string", "enum": ["STRATEGIC_BRIEF", "RESEARCH", "DELIVERABLE", "DECISION_LOG", "CONVERSATION_EXTRACT", "SKILL", "SCHEMA", "CHARTER", "FINANCIAL", "LEGAL", "MARKETING", "OPERATIONAL", "REFERENCE", "UNKNOWN"] },
        "source_type": { "type": "string", "enum": ["TIM_PROVIDED", "AGENT_GENERATED", "EXTERNAL_RESEARCH", "CONVERSATION_CAPTURE", "SYSTEM_OUTPUT"] },
        "citation_tier": { "type": "string", "enum": ["TIER_A_ELIGIBLE", "TIER_B_CONFIRMED", "TIER_C_INFERENCE_ONLY", "TIER_D_VERBAL_SOCIAL", "NOT_CITABLE"] },
        "date_ingested": { "type": "string", "format": "date-time" },
        "ingested_by": { "type": "string" },
        "vault_path": { "type": "string", "pattern": "^/home/ubuntu/mavens-knowledge-vault/" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "duplicate_check_performed": { "const": true },
        "pii_scan_performed": { "const": true },
        "escalation_required": { "type": "boolean" }
      },
      "if": {
        "properties": { "project": { "const": "UNCLASSIFIED" } }
      },
      "then": {
        "required": ["escalation_required"],
        "properties": { "escalation_required": { "const": true } }
      }
    },
    "intelligence_brief": {
      "type": "object",
      "required": ["what", "where", "why_relevant", "score", "recommendation", "awaiting_approval", "status"],
      "properties": {
        "what": { "type": "string" },
        "where": { "type": "string" },
        "why_relevant": { "type": "object", "required": ["project", "north_star", "job_to_be_done"], "properties": { "project": { "type": "string" }, "north_star": { "type": "string" }, "job_to_be_done": { "type": "string" } } },
        "score": { "type": "integer", "minimum": 65, "maximum": 110 },
        "recommendation": { "type": "string", "enum": ["COMMIT", "HOLD", "DISCARD"] },
        "awaiting_approval": { "type": "array", "items": { "type": "string", "enum": ["TIM_HB1000", "MASTER_JEEVES"] } },
        "status": { "type": "string", "enum": ["PENDING_APPROVAL", "APPROVED_COMMIT", "APPROVED_HOLD", "VETOED_DISCARD", "AUTO_HOLD_48H"] }
      }
    },
    "discarded_item": {
        "type": "object",
        "required": ["what", "where", "why_discarded", "score", "evaluated_for_project", "evaluated_for_north_star", "date_discarded", "tags", "themes"],
        "properties": {
            "what": { "type": "string" },
            "where": { "type": "string" },
            "why_discarded": { "type": "string" },
            "score": { "type": "integer", "maximum": 64 },
            "evaluated_for_project": { "type": "string" },
            "evaluated_for_north_star": { "type": "string" },
            "date_discarded": { "type": "string", "format": "date-time" },
            "tags": { "type": "array", "items": { "type": "string" } },
            "themes": { "type": "array", "items": { "type": "string" } }
        }
    },
    "swarm_signal_brief": {
        "type": "object",
        "required": ["signal_type", "cluster", "pattern_detected", "combined_score", "why_now", "recommendation", "awaiting_approval"],
        "properties": {
            "signal_type": { "const": "SWARM_SIGNAL" },
            "cluster": { "type": "array", "items": { "$ref": "#/definitions/discarded_item" } },
            "pattern_detected": { "type": "string" },
            "combined_score": { "type": "integer", "minimum": 65 },
            "why_now": { "type": "string" },
            "recommendation": { "type": "string", "enum": ["COMMIT_SYNTHESIS", "INVESTIGATE_FURTHER", "HOLD"] },
            "awaiting_approval": { "type": "array", "items": { "type": "string", "enum": ["TIM_HB1000", "MASTER_JEEVES"] } }
        }
    },
    "cluster_detection": {
        "type": "object",
        "required": ["minimum_items", "minimum_shared_tags", "combined_score_threshold"],
        "properties": {
            "minimum_items": { "const": 3 },
            "minimum_shared_tags": { "const": 2 },
            "combined_score_threshold": { "const": 65 }
        }
    }
  },
  "additionalProperties": false
}
