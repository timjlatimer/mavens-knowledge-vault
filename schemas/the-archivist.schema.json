{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/timjlatimer/mavens-knowledge-vault/schemas/the-archivist.schema.json",
  "title": "The Archivist v1.0 Enforcement Schema",
  "description": "Machine-enforceable companion schema for The Archivist skill. All intake and proactive intelligence outputs must validate against this schema. Failure to validate = REJECTED.",
  "type": "object",
  "required": ["operating_mode"],
  "properties": {
    "operating_mode": {
      "type": "string",
      "enum": ["REACTIVE", "PROACTIVE", "BOTH"]
    },
    "intake_item": {
      "type": "object",
      "description": "Schema for a single item being processed in REACTIVE intake mode.",
      "required": [
        "project",
        "north_star",
        "document_type",
        "source_type",
        "citation_tier",
        "date_ingested",
        "ingested_by",
        "vault_path",
        "duplicate_check_performed",
        "pii_scan_performed"
      ],
      "properties": {
        "project": {
          "type": "string",
          "minLength": 1,
          "description": "Which Bingo Card or initiative this belongs to. If UNCLASSIFIED, must escalate to Master Jeeves."
        },
        "north_star": {
          "type": "string",
          "minLength": 1,
          "description": "Which North Star governs this project. MUST NOT default to Ruby Red unless explicitly confirmed for this specific project."
        },
        "document_type": {
          "type": "string",
          "enum": [
            "STRATEGIC_BRIEF",
            "RESEARCH",
            "DELIVERABLE",
            "DECISION_LOG",
            "CONVERSATION_EXTRACT",
            "SKILL",
            "SCHEMA",
            "CHARTER",
            "FINANCIAL",
            "LEGAL",
            "MARKETING",
            "OPERATIONAL",
            "REFERENCE",
            "UNKNOWN"
          ]
        },
        "source_type": {
          "type": "string",
          "enum": [
            "TIM_PROVIDED",
            "AGENT_GENERATED",
            "EXTERNAL_RESEARCH",
            "CONVERSATION_CAPTURE",
            "SYSTEM_OUTPUT"
          ]
        },
        "citation_tier": {
          "type": "string",
          "enum": [
            "TIER_A_ELIGIBLE",
            "TIER_B_CONFIRMED",
            "TIER_C_INFERENCE_ONLY",
            "TIER_D_VERBAL_SOCIAL",
            "NOT_CITABLE"
          ]
        },
        "date_ingested": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of when the item was ingested."
        },
        "ingested_by": {
          "type": "string",
          "description": "The ID of the agent performing the intake (e.g., The Archivist v1.0)."
        },
        "vault_path": {
          "type": "string",
          "pattern": "^/home/ubuntu/mavens-knowledge-vault/",
          "description": "The full, absolute path where the item was committed in the vault."
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "A free-form array of searchable keywords."
        },
        "duplicate_check_performed": {
          "const": true,
          "description": "Confirms that the item was checked for duplication before commit. Part of the blocking rule protocol."
        },
        "pii_scan_performed": {
          "const": true,
          "description": "Confirms that the item was scanned for PII before commit. Part of the blocking rule protocol."
        },
        "escalation_required": {
          "type": "boolean",
          "description": "If true, this item requires review by Master Jeeves for classification."
        }
      },
      "if": {
        "properties": { "project": { "const": "UNCLASSIFIED" } }
      },
      "then": {
        "required": ["escalation_required"],
        "properties": { "escalation_required": { "const": true } }
      }
    },
    "proactive_scan_results": {
      "type": "array",
      "description": "Array of intelligence briefs generated in PROACTIVE mode.",
      "items": {
        "$ref": "#/definitions/intelligence_brief"
      }
    },
    "discard_log": {
      "type": "array",
      "description": "Log of items found in proactive mode but discarded for scoring below the threshold.",
      "items": {
        "type": "object",
        "required": ["what", "score", "reason"],
        "properties": {
          "what": { "type": "string" },
          "score": { "type": "integer", "maximum": 64 },
          "reason": { "type": "string" }
        }
      }
    }
  },
  "definitions": {
    "intelligence_brief": {
      "type": "object",
      "required": [
        "what",
        "where",
        "why_relevant",
        "score",
        "recommendation",
        "awaiting_approval",
        "status"
      ],
      "properties": {
        "what": {
          "type": "string",
          "description": "Title, source, and URL/reference of the found item."
        },
        "where": {
          "type": "string",
          "description": "Where the item was found (e.g., Google Scholar, specific industry journal)."
        },
        "why_relevant": {
          "type": "object",
          "required": ["project", "north_star", "job_to_be_done"],
          "properties": {
            "project": { "type": "string" },
            "north_star": { "type": "string" },
            "job_to_be_done": { "type": "string" }
          }
        },
        "score": {
          "type": "integer",
          "minimum": 65,
          "maximum": 110,
          "description": "0-110 score with brief rationale. Must be >= 65 to be escalated."
        },
        "recommendation": {
          "type": "string",
          "enum": ["COMMIT", "HOLD", "DISCARD"]
        },
        "awaiting_approval": {
          "type": "array",
          "description": "Decision from Tim HB1000 OR Master Jeeves (Joint Brain model).",
          "items": {
            "type": "string",
            "enum": ["TIM_HB1000", "MASTER_JEEVES"]
          }
        },
        "status": {
          "type": "string",
          "enum": ["PENDING_APPROVAL", "APPROVED_COMMIT", "APPROVED_HOLD", "VETOED_DISCARD", "AUTO_HOLD_48H"],
          "description": "Current status of the brief."
        }
      }
    }
  },
  "additionalProperties": false
}
